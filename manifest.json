{
  "manifest_version": 3,
  "name": "Second Brain",
  "version": "0.1.0",
  "description": "AI-powered bookmark manager",

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Second Brain"
  },

  "background": {
    "service_worker": "background.js"
  }
}